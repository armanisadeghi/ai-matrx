      "title": "ImageLora",
      "type": "object"
    },
    "JsonValue": {},
    "MediaRef": {
      "additionalProperties": true,
      "description": "Canonical media reference shared across every API that takes media.",
      "properties": {
        "file_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "cld_files UUID. Preferred form; returned by POST /files/upload.",
          "title": "File Id"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Any URL we issued (share link, /files/{id}/url, /files/{id}/download, raw S3 URL) or a truly external https://. The server recognises ours and resolves to bytes; external URLs are passed through to providers that fetch them, or downloaded as a last resort.",
          "title": "Url"
        },
        "file_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Native cloud URI: s3://bucket/key, gs://..., supabase://...",
          "title": "File Uri"
        },
        "mime_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Hint from the client. Server REPLACES with the canonical cld_files.mime_type when the reference resolves to one of our files.",
          "title": "Mime Type"
        },
        "metadata": {
          "additionalProperties": true,
          "description": "Free-form per-API metadata. Opaque to the resolver.",
          "title": "Metadata",
          "type": "object"
        },
        "vision_class": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional name of a registered vision class (e.g. 'anthropic_opus_hires', 'gemini3_high'). When set, resolution produces a derived variant of the master file using the host-registered encoder for the 'vision' family. Wire-stable: frontends and tools may pin a specific variant; otherwise the unified client annotates this field based on the target model.",
          "title": "Vision Class"
        },
        "base64_data": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inline bytes (base64). Set by resolver when needs_bytes=True.",
          "title": "Base64 Data"
        },
        "resolved_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fresh presigned URL the resolver minted (provider-fetchable).",
          "title": "Resolved Url"
        },
        "file_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File Size"
        },
        "owner_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Owner Id"
        },
        "is_ours": {
          "default": false,
          "description": "True iff the resolver matched the reference to a cld_files row.",
          "title": "Is Ours",
          "type": "boolean"
        },
        "resolver_error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Set when resolution failed; surface to the caller for logging.",
          "title": "Resolver Error"
        },
        "is_resolved": {
          "default": false,
          "description": "Set to True by the boundary normaliser. Resolvers short-circuit when this is True (idempotency). Internal — clients do not set.",
          "title": "Is Resolved",
          "type": "boolean"
        }
      },
      "title": "MediaRef",
      "type": "object"
    },
