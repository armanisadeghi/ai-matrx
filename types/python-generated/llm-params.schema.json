    "CompactionSettings": {
      "additionalProperties": false,
      "description": "Optional overrides for the 5-tier context compaction pipeline.\n\nRarely sent by clients today — reserved for explicit compaction control.",
      "properties": {
        "tier2_minimal_prune": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tier2 Minimal Prune"
        },
        "tier3_content_to_retrieval": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tier3 Content To Retrieval"
        },
        "tier4_threshold_trim": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tier4 Threshold Trim"
        },
        "tier5_hard_compression": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tier5 Hard Compression"
        }
      },
      "title": "CompactionSettings",
      "type": "object"
    },
    "CustomTool": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "Unique tool name. Must match [a-zA-Z0-9_-]{1,64}.",
